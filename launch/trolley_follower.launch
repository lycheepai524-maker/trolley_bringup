<launch>
  <!-- ===== 1. Robot description ===== -->
  <param name="robot_description"
       textfile="$(find trolley_bringup)/urdf/trolley.urdf"/>
  <node name="robot_state_publisher" pkg="robot_state_publisher"
        type="robot_state_publisher"/>

  <!-- ===== 2. Arduino bridge — listens to /cmd_vel ===== -->
  <node name="arduino_serial" pkg="rosserial_python" type="serial_node.py"
        output="screen">
    <param name="port" value="/dev/ttyACM0"/>
    <param name="baud" value="57600"/>
  </node>

  <!-- ===== 3. LiDAR ===== -->
  <include file="$(find ydlidar_ros_driver)/launch/X3.launch"/>
  <node pkg="tf" type="static_transform_publisher" name="base_to_laser_broadcaster"
        args="0.765 0 0.145 3.14159 0 0 base_link laser 100"/>

  <!-- ===== 4. cmd_vel boost: listens on /cmd_vel_in, publishes /cmd_vel =====
       Pipeline:  follower -> /cmd_vel_in -> cmd_vel_boost -> /cmd_vel -> arduino  -->
  <node pkg="trolley_bringup" type="cmd_vel_boost.py" name="cmd_vel_boost"
        output="screen">
    <remap from="cmd_vel_in"  to="/cmd_vel_in"/>
    <remap from="cmd_vel_out" to="/cmd_vel"/>
    <param name="min_linear"        value="0.50"/>
    <param name="min_angular"       value="2.20"/>
    <param name="linear_deadband"   value="0.02"/>
    <param name="angular_deadband"  value="0.05"/>
  </node>

  <!-- ===== 5. LiDAR follower (already publishes to /cmd_vel_in) ===== -->
  <node pkg="trolley_bringup" type="lidar_follower.py" name="lidar_follower"
        output="screen">
    <param name="follow_distance"      value="0.5"/>
    <param name="distance_tolerance"   value="0.05"/>
    <param name="safety_distance"      value="0.3"/>
    <param name="search_angle"         value="0.785"/>
    <param name="min_range"            value="0.30"/>
    <param name="max_range"            value="3.0"/>
    <param name="max_lin_vel"          value="0.5"/>
    <param name="max_ang_vel"          value="1.5"/>
    <param name="lin_gain"             value="1.2"/>
    <param name="ang_gain"             value="2.0"/>
    <param name="max_distance_change"  value="0.8"/>
    <param name="max_bearing_change"   value="1.0"/>
    <param name="lost_timeout"         value="2.5"/>
  </node>
</launch>
