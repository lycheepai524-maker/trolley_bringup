<launch>
  <!-- ===== 1. Robot description ===== -->
  <param name="robot_description"
       textfile="$(find trolley_bringup)/urdf/trolley.urdf"/>
  <node name="robot_state_publisher" pkg="robot_state_publisher"
        type="robot_state_publisher"/>
  <node pkg="tf2_ros" type="static_transform_publisher" name="base_link_to_footprint"
        args="0 0 0 0 0 0 base_link base_footprint"/>

  <!-- ===== 2. Arduino bridge ===== -->
  <node name="arduino_serial" pkg="rosserial_python" type="serial_node.py"
        output="screen">
    <param name="port" value="/dev/ttyACM0"/>
    <param name="baud" value="57600"/>
  </node>

  <!-- ===== 3. Encoder odom — NOW PUBLISHES TF (odom -> base_link) ===== -->
  <node pkg="trolley_bringup" type="encoder_to_odom.py" name="encoder_to_odom"
        output="screen">
    <param name="ticks_per_meter" value="4848.0"/>
    <param name="track_width"     value="0.46"/>
    <param name="publish_rate"    value="30.0"/>
    <param name="base_frame"      value="base_link"/>
    <param name="odom_frame"      value="odom"/>
    <param name="invert_left"     value="false"/>
    <param name="invert_right"    value="true"/>
    <param name="publish_tf"      value="true"/>   <!-- IMPORTANT for nav -->
  </node>

  <!-- ===== 4. LiDAR ===== -->
  <include file="$(find ydlidar_ros_driver)/launch/X3.launch"/>
  <node pkg="tf" type="static_transform_publisher" name="base_to_laser_broadcaster"
        args="0.765 0 0.145 0 0 0 base_link laser 100"/>

  <!-- ===== 5. Map server ===== -->
  <arg name="map_file" default="$(env HOME)/maps/hokme.yaml"/>
  <node name="map_server" pkg="map_server" type="map_server" args="$(arg map_file)"/>

  <!-- ===== 6. AMCL localization ===== -->
  <node pkg="amcl" type="amcl" name="amcl" output="screen">
    <param name="odom_frame_id"  value="odom"/>
    <param name="base_frame_id"  value="base_link"/>
    <param name="global_frame_id" value="map"/>
    <param name="odom_model_type" value="diff"/>
    <param name="min_particles"  value="500"/>
    <param name="max_particles"  value="3000"/>
    <param name="update_min_d"   value="0.1"/>
    <param name="update_min_a"   value="0.2"/>
    <param name="laser_max_beams" value="180"/>
    <param name="transform_tolerance" value="0.2"/>
    <param name="initial_pose_x"  value="0.0"/>
    <param name="initial_pose_y"  value="0.0"/>
    <param name="initial_pose_a"  value="0.0"/>
  </node>

  <!-- ===== 7. WiFi initial-pose seeder ===== -->
  <node pkg="trolley_bringup" type="wifi_initial_pose.py" name="wifi_initial_pose"
        output="screen">
    <param name="db_path"        value="$(env HOME)/trolley_fingerprintsC0706.db"/>
    <param name="wifi_interface" value="wlan0"/>
    <param name="k"              value="3"/>
  </node>

  <!-- ===== 8. move_base ===== -->
  <node pkg="move_base" type="move_base" name="move_base" output="screen">
    <rosparam file="$(find trolley_bringup)/config/nav/costmap_common.yaml"
          command="load" ns="global_costmap"/>
    <rosparam file="$(find trolley_bringup)/config/nav/costmap_common.yaml"
          command="load" ns="local_costmap"/>
    <rosparam file="$(find trolley_bringup)/config/nav/costmap_global.yaml"
          command="load"/>
    <rosparam file="$(find trolley_bringup)/config/nav/costmap_local.yaml"
          command="load"/>
    <rosparam file="$(find trolley_bringup)/config/nav/dwa_planner.yaml"
          command="load"/>
    <param name="base_local_planner" value="dwa_local_planner/DWAPlannerROS"/>
    <param name="base_global_planner" value="global_planner/GlobalPlanner"/>
    <rosparam>
     GlobalPlanner:
       use_dijkstra: false   # false = A*, true = Dijkstra
       use_grid_path: false
       allow_unknown: true
</rosparam>
  </node>
</launch>
