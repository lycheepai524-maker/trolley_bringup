<launch>
  <!-- OBSTACLE AVOIDANCE ONLY (no map, no AMCL, no WiFi).
       Goals in 'odom' frame. NO RECOVERY behaviors. -->

  <!-- ===== 1. Robot description ===== -->
  <param name="robot_description"
       textfile="$(find trolley_bringup)/urdf/trolley.urdf"/>
  <node name="robot_state_publisher" pkg="robot_state_publisher"
        type="robot_state_publisher"/>
  <node pkg="tf2_ros" type="static_transform_publisher" name="base_link_to_footprint"
        args="0 0 0 0 0 0 base_link base_footprint"/>

  <!-- ===== 2. Arduino bridge ===== -->
  <node name="arduino_serial" pkg="rosserial_python" type="serial_node.py"
        output="screen">
    <remap from="cmd_vel" to="cmd_vel_raw"/>
    <param name="port" value="/dev/ttyACM0"/>
    <param name="baud" value="57600"/>
  </node>

  <!-- ===== 3. Encoder odom ===== -->
  <node pkg="trolley_bringup" type="encoder_to_odom.py" name="encoder_to_odom"
        output="screen">
    <param name="ticks_per_meter" value="4848.0"/>
    <param name="track_width"     value="0.46"/>
    <param name="publish_rate"    value="30.0"/>
    <param name="base_frame"      value="base_link"/>
    <param name="odom_frame"      value="odom"/>
    <param name="invert_left"     value="false"/>
    <param name="invert_right"    value="true"/>
    <param name="publish_tf"      value="true"/>
  </node>

  <!-- ===== 4. LiDAR ===== -->
  <include file="$(find ydlidar_ros_driver)/launch/X3.launch"/>
  <param name="/ydlidar_lidar_publisher/range_min" value="0.50"/>
  <node pkg="tf" type="static_transform_publisher" name="base_to_laser_broadcaster"
        args="0.765 0 0.145 3.14159 0 0 base_link laser 100"/>

  <!-- ===== 5. cmd_vel boost ===== -->
  <node pkg="trolley_bringup" type="cmd_vel_boost.py" name="cmd_vel_boost"
        output="screen">
    <remap from="cmd_vel_in"  to="cmd_vel"/>
    <remap from="cmd_vel_out" to="cmd_vel_raw"/>
    <param name="min_linear"   value="0.50"/>
    <param name="min_angular"  value="2.20"/>
    <param name="linear_deadband"  value="0.02"/>
    <param name="angular_deadband" value="0.05"/>
  </node>

  <!-- ===== 6. move_base ===== -->
  <node pkg="move_base" type="move_base" name="move_base" output="screen">
    <rosparam file="$(find trolley_bringup)/config/nav/costmap_common.yaml"
              command="load" ns="global_costmap"/>
    <rosparam file="$(find trolley_bringup)/config/nav/costmap_common.yaml"
              command="load" ns="local_costmap"/>
    <rosparam file="$(find trolley_bringup)/config/nav/costmap_local.yaml"
              command="load"/>
    <rosparam file="$(find trolley_bringup)/config/nav/dwa_planner.yaml"
              command="load"/>

    <!-- Global costmap: rolling window in odom, NO static map, subscribes to laser -->
    <param name="global_costmap/global_frame"      value="odom"/>
    <param name="global_costmap/robot_base_frame"  value="base_link"/>
    <param name="global_costmap/static_map"        value="false"/>
    <param name="global_costmap/rolling_window"    value="true"/>
    <param name="global_costmap/width"             value="10.0"/>
    <param name="global_costmap/height"            value="10.0"/>
    <param name="global_costmap/resolution"        value="0.05"/>
    <!-- AGGRESSIVE UPDATES so global plan reflects new obstacles fast -->
    <param name="global_costmap/update_frequency"  value="5.0"/>
    <param name="global_costmap/publish_frequency" value="2.0"/>

    <param name="base_local_planner"  value="dwa_local_planner/DWAPlannerROS"/>
    <param name="base_global_planner" value="navfn/NavfnROS"/>

    <!-- =====  PLAN OFTEN to track new obstacles  ===== -->
    <!-- Replan from scratch every 0.5 s — old plan through new obstacle
         gets discarded fast. -->
    <param name="planner_frequency"          value="2.0"/>

    <!-- =====  SAFETY: NO RECOVERY  ===== -->
    <param name="recovery_behavior_enabled"  value="false"/>
    <param name="clearing_rotation_allowed"  value="false"/>
    <param name="planner_patience"           value="3.0"/>
    <param name="controller_patience"        value="3.0"/>
    <param name="max_planning_retries"       value="2"/>

    <param name="oscillation_timeout"        value="6.0"/>
    <param name="oscillation_distance"       value="0.3"/>
  </node>
</launch>
